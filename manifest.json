{
  "name": "reedy",
  "version": "1.0.0",
  "description": "Open Claude responses in the Reedy RSVP speed reader. Send responses with /reedy, manage with /reedy stop and /reedy clean.",
  "author": "Josh Hale",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/claude-reedy-skill.git"
  },
  "keywords": [
    "speed-reading",
    "rsvp",
    "reedy",
    "productivity",
    "reading"
  ],
  "main": "SKILL.md",
  "engines": {
    "claude-code": ">=1.0.0"
  },
  "requirements": {
    "python": ">=3.6",
    "browser-extension": "Reedy Chrome Extension"
  },
  "commands": {
    "/reedy": "Send last Claude response to Reedy speed reader",
    "/reedy [prompt]": "Answer a prompt and send response to Reedy",
    "/reedy setup": "Verify Python 3 and skill installation",
    "/reedy stop": "Stop the Reedy local server",
    "/reedy clean": "Clear Reedy reading history"
  },
  "homepage": "https://github.com/yourusername/claude-reedy-skill",
  "bugs": {
    "url": "https://github.com/yourusername/claude-reedy-skill/issues"
  }
}
