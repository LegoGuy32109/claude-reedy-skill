#!/usr/bin/env python3
"""
reedy-serve: Persistent SPA for Reedy speed reader history.

Usage:
  python3 reedy-serve --ingest SLUG   # pipe text via stdin; starts server if needed
  python3 reedy-serve --stop          # stop the running server
  python3 reedy-serve --list          # print history file names
  python3 reedy-serve --clean         # delete all history files
  python3 reedy-serve --server        # run HTTP server (spawned internally)
"""

import os, sys, socket, subprocess, time, json, re, platform, shlex
from pathlib import Path
from datetime import datetime
from http.server import HTTPServer, BaseHTTPRequestHandler
from urllib.parse import urlparse

PORT = 7766


# ── Platform-correct data directory ─────────────────────────────────────────

def data_dir() -> Path:
    return Path.home() / '.local' / 'share' / 'reedy'


# ── Server health check ──────────────────────────────────────────────────────

def server_running() -> bool:
    try:
        s = socket.create_connection(('127.0.0.1', PORT), timeout=0.5)
        s.close()
        return True
    except OSError:
        return False


def start_server_daemon():
    subprocess.Popen(
        [sys.executable, os.path.abspath(__file__), '--server'],
        start_new_session=True,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    for _ in range(30):
        time.sleep(0.15)
        if server_running():
            return
    raise RuntimeError('Reedy server failed to start within 5s')


# ── SPA HTML (baked-in, never written to disk) ───────────────────────────────

SPA_HTML = r"""<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Reedy</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
