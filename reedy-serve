  </div>
</div>

<script>
let current = null;

function titleFromSlug(slug) {
  let m = slug.match(/^\d{4}-\d{2}-\d{2}_\d{2}-\d{2}_(.+)$/);
  return (m ? m[1] : slug).replace(/-/g,' ');
}
function dateFromSlug(slug) {
  let m = slug.match(/^(\d{4}-\d{2}-\d{2})_(\d{2})-(\d{2})_/);
  if (!m) return '';
  try {
    let d = new Date(m[1]+'T'+m[2]+':'+m[3]);
    return d.toLocaleString([],{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'});
  } catch(e){ return m[1]; }
}

async function loadSlug(slug) {
  current = slug;
  const r = await fetch('/content/'+slug+'.txt');
  if (!r.ok) return;
  const text = await r.text();

  document.getElementById('waiting').style.display = 'none';
  const el = document.getElementById('content');
  el.textContent = text;

  document.getElementById('hint').classList.add('on');
  document.getElementById('hint').innerHTML = 'Press <strong>Alt+S</strong> to start reading · No Reedy? <a href="https://chromewebstore.google.com/detail/speed-reading/ihbdojmggkmjbhfflnchljfkgdhokffj" target="_blank">Install extension</a>';
  document.title = titleFromSlug(slug);
  renderSidebarActive();
}

let cachedFiles = [];

function renderSidebarActive() {
  document.querySelectorAll('.item').forEach(i => {
    i.classList.toggle('active', i.dataset.slug === current);
  });
}

async function refreshSidebar() {
  const r = await fetch('/api/files');
  if (!r.ok) return;
  cachedFiles = await r.json();
  const list = document.getElementById('history-list');
  if (!cachedFiles.length) {
    list.innerHTML = '<div class="empty-history">No history yet.</div>';
    return;
  }
  list.innerHTML = cachedFiles.map(slug => `
    <div class="item ${slug===current?'active':''}" data-slug="${slug}"
         onclick="loadSlug('${slug}')">
      <div class="title">${titleFromSlug(slug)}</div>
      <div class="date">${dateFromSlug(slug)}</div>
    </div>`).join('');
}

async function autoLoadMostRecent() {
  const r = await fetch('/api/files');
  if (r.ok) {
    const files = await r.json();
    if (files.length > 0) {
      await loadSlug(files[0]);
    }
  }
}

async function pollPending() {
  try {
    const r = await fetch('/api/pending');
    if (r.ok) {
      const d = await r.json();
      if (d.slug) {
        await refreshSidebar();
        await loadSlug(d.slug);
      }
    }
  } catch(e){}
  setTimeout(pollPending, 500);
}

refreshSidebar();
autoLoadMostRecent();
pollPending();
</script>
</body>
</html>"""


# ── HTTP request handler ─────────────────────────────────────────────────────

class Handler(BaseHTTPRequestHandler):
    def log_message(self, *a): pass

    def _send(self, body: bytes, status=200, ctype='text/plain; charset=utf-8'):
        self.send_response(status)
        self.send_header('Content-Type', ctype)
        self.send_header('Content-Length', str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _json(self, data, status=200):
        self._send(json.dumps(data).encode(), status, 'application/json')

    def do_GET(self):
        path = urlparse(self.path).path

        if path == '/':
            self._send(SPA_HTML.encode(), ctype='text/html; charset=utf-8')

        elif path == '/api/pending':
            p = data_dir() / '.pending'
            if p.exists():
                slug = p.read_text(encoding='utf-8').strip()
                p.unlink(missing_ok=True)
                self._json({'slug': slug})
            else:
                self._json({})

        elif path == '/api/files':
            d = data_dir()
            slugs = sorted(
                [f.stem for f in d.glob('????-??-??_??-??_*.txt')],
                reverse=True
            )
            self._json(slugs)

        elif path.startswith('/content/') and path.endswith('.txt'):
            slug = path[9:-4]
            if re.search(r'[/\\.]', slug):   # no traversal
                self._send(b'not found', 404)
                return
            f = data_dir() / (slug + '.txt')
            if f.exists():
                self._send(f.read_bytes(), ctype='text/plain; charset=utf-8')
            else:
                self._send(b'not found', 404)
        else:
            self._send(b'not found', 404)

    def do_POST(self):
        if self.path == '/api/stop':
            self._json({'ok': True})
            import threading
            threading.Thread(target=self.server.shutdown, daemon=True).start()
        else:
            self._send(b'not found', 404)


# ── Modes ────────────────────────────────────────────────────────────────────

def mode_write_runtime(plugin_root: str):
    """Write session runtime config so commands know which python/script to use."""
    d = data_dir()
    d.mkdir(parents=True, exist_ok=True)
    script_path = str(Path(plugin_root) / 'reedy-serve')
    python_cmd = sys.executable
    (d / 'reedy.env').write_text(
        f'REEDY_PY={shlex.quote(python_cmd)}\n'
        f'REEDY_SCRIPT={shlex.quote(script_path)}\n',
        encoding='utf-8'
    )


def mode_ingest(raw_slug: str, file_path: str | None = None):
    """Read text from file or stdin, save as timestamped .txt, set as pending, start server."""
    d = data_dir()
    d.mkdir(parents=True, exist_ok=True)

    if file_path:
        text = Path(file_path).read_text(encoding='utf-8')
    else:
        text = sys.stdin.read()

    # Prepend timestamp if slug doesn't already have one
    if not re.match(r'^\d{4}-\d{2}-\d{2}_\d{2}-\d{2}_', raw_slug):
        ts = datetime.now().strftime('%Y-%m-%d_%H-%M')
        slug = f'{ts}_{raw_slug}'
    else:
        slug = raw_slug

    (d / (slug + '.txt')).write_text(text, encoding='utf-8')
    (d / '.pending').write_text(slug, encoding='utf-8')

    import webbrowser
    if not server_running():
        start_server_daemon()
    webbrowser.open(f'http://localhost:{PORT}/')


def mode_stop():
    import urllib.request, urllib.error
    try:
        urllib.request.urlopen(
            urllib.request.Request(
                f'http://localhost:{PORT}/api/stop',
                method='POST', data=b''
            ),
            timeout=3
        )
        print('Reedy server stopped.')
    except urllib.error.URLError:
        print('Reedy server is not running.')


def mode_list():
    d = data_dir()
    files = sorted(d.glob('????-??-??_??-??_*.txt'), reverse=True)
    if not files:
        print('(no history files)')
    else:
        for f in files:
            print(f.name)


def mode_clean():
    d = data_dir()
    files = list(d.glob('????-??-??_??-??_*.txt'))
    for f in files:
        f.unlink()
    (d / '.pending').unlink(missing_ok=True)
    print(f'Deleted {len(files)} file(s).')


def mode_server():
    d = data_dir()
    d.mkdir(parents=True, exist_ok=True)
    httpd = HTTPServer(('127.0.0.1', PORT), Handler)
    httpd.serve_forever()


# ── Entry point ──────────────────────────────────────────────────────────────

if __name__ == '__main__':
    args = sys.argv[1:]
    if not args:
        print(__doc__)
        sys.exit(1)

    cmd = args[0]
    if cmd == '--server':
        mode_server()
    elif cmd == '--stop':
        mode_stop()
    elif cmd == '--list':
        mode_list()
    elif cmd == '--clean':
        mode_clean()
    elif cmd == '--write-runtime' and len(args) >= 2:
        mode_write_runtime(args[1])
    elif cmd == '--ingest' and len(args) >= 2:
        file_path = next((args[i + 1] for i, a in enumerate(args) if a == '--file'), None)
        mode_ingest(args[1], file_path)
    else:
        print(f'Unknown: {args}', file=sys.stderr)
        sys.exit(1)
